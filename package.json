{
  "name": "plotkitch-server",
  "version": "0.1.0",
  "description": "Plokitch Backend API — Fastify + Drizzle + Supabase + Better Auth",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx auth@latest generate --config src/lib/auth.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.6.0",
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.43.1",
    "fastify": "^4.28.1",
    "pg": "^8.14.1",
    "postgres": "^3.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/pg": "^8.11.15",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
