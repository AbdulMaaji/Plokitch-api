# ──────────────────────────────────────────────
# Plokitch Server — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Better Auth ───────────────────────────────
# Generate a secret: npx better-auth secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Database connection string (PostgreSQL via Supabase)
# Use the pooler URL for the application and the direct URL for migrations
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── CORS ──────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000

# ── Marketplace (invite acceptance links) ─────
# Base URL of the operator-facing app where /accept-invite is served.
MARKETPLACE_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────
# REQUIRED in production. If RESEND_API_KEY is unset while NODE_ENV=production,
# the server fails fast at startup (vendor & rider invite emails would otherwise
# silently never send). In development, a missing key falls back to a console
# preview of the email.
RESEND_API_KEY=
# Verified sender, e.g. "Plokitch Onboarding <onboarding@plokitch.app>"
EMAIL_FROM=Plokitch Onboarding <onboarding@resend.dev>
# Reply-to address shown to invited vendors/riders.
EMAIL_REPLY_TO=support@plokitch.app
# Internal inbox that receives new "Join Us" application alerts (falls back to EMAIL_REPLY_TO).
ADMIN_ALERT_EMAIL=ops@plokitch.app

# ── Admin dashboard (Next.js) ─────────────────
# Used to build review links inside admin alert emails.
DASHBOARD_URL=http://localhost:3000
